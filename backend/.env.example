APP_ENV=dev
JWT_SECRET=change-me
JWT_ISSUER=my-jeja-backend
JWT_AUDIENCE=my-jeja-app
CORS_ALLOW_ORIGINS=http://localhost:19006,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Example: postgresql+asyncpg://user:pass@localhost:5432/myjeja
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/myjeja
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_FAIL_CLOSED=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
SENTRY_DSN=
