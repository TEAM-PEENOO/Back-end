APP_ENV=dev
JWT_SECRET=change-me
JWT_ISSUER=my-jeja-backend
JWT_AUDIENCE=my-jeja-app
AUTH_GOOGLE_ONLY=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_APP_REDIRECT_DEFAULT=http://localhost:19006/google-oauth-callback
CORS_ALLOW_ORIGINS=http://localhost:19006,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Railway often gives: postgresql://...
# Backend normalizes postgresql:// to postgresql+asyncpg:// automatically.
DATABASE_URL=postgresql://user:pass@localhost:5432/myjeja
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_FAIL_CLOSED=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
SENTRY_DSN=
